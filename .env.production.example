# Production Environment Configuration
# Copy this file to .env on the EC2 server and fill in real values.
# NEVER commit the real .env file to git.

# ── Database — AWS RDS PostgreSQL 15 (ap-southeast-4 Melbourne) ───────────────
# Get RDS endpoint from: cd terraform && terraform output rds_endpoint
DATABASE_URL=postgresql://signatureshades_prod:CHANGE_THIS_TO_STRONG_PASSWORD@signatureshades-db-production.XXXXXXXXX.ap-southeast-4.rds.amazonaws.com:5432/signatureshades_prod

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
CORS_ORIGIN=https://orders.signatureshades.com.au

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=https://orders.signatureshades.com.au/api

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64   (join output into one line — no newlines)
JWT_SECRET=GENERATE_SECURE_RANDOM_STRING_HERE
JWT_EXPIRES_IN=8h

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-4
AWS_S3_BUCKET=signatureshades-bend-drawings

# ── Postgres vars (used by seed/admin scripts only) ───────────────────────────
POSTGRES_USER=signatureshades_prod
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
POSTGRES_DB=signatureshades_prod

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=warn
