# Normalize line endings to LF in the repository; Git will convert to CRLF on Windows checkout
* text=auto eol=lf

# Explicitly set common text file types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env  text eol=lf

# Dockerfile
Dockerfile text eol=lf

# Shell scripts must stay LF
*.sh text eol=lf

# Binary files — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
*.pdf  binary
*.zip  binary
